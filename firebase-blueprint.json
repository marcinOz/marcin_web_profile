{
  "entities": {
    "Message": {
      "title": "Message",
      "description": "A contact message sent from the portfolio website.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Name of the sender"
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "Email of the sender"
        },
        "message": {
          "type": "string",
          "description": "Content of the message"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the message was sent"
        }
      },
      "required": ["name", "email", "message", "createdAt"]
    }
  },
  "firestore": {
    "messages/{messageId}": {
      "schema": {
        "$ref": "#/entities/Message"
      },
      "description": "Collection of contact messages."
    }
  }
}
